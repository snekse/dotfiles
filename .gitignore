# "Dotfiles Project" specific — exclude local settings, allow committed commands
.claude/*
!.claude/commands/

# Override global gitignore's "bin/" rule — this bin/ holds standalone scripts on $PATH
!bin/

# Fish
/fish/completions/*.fish
/fish/fish_variables
/fish/config.fish.backup

# Local
# git credential file
.gitconfig.local

# Lock files
Brewfile.lock.json

# Build and module DIRs
node_modules/
build/

# Folder view configuration files
.DS_Store
Desktop.ini

# Thumbnail cache files
Thumbs.db

# Files that might appear on external disks
.Trashes

# Cloud & infrastructure credentials
.aws/
.azure/
.config/gcloud/
.kube/
.terraform.d/

# Package manager & tool credentials
.npmrc
.pypirc
.gem/
auth.json
.docker/config.json
.git-credentials

# Shell & REPL history
.*_history

# Encryption & identity
.gnupg/
.gpg/
*.pem
*.key
*.pkcs12