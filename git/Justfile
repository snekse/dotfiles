# Set up machine-local git identity fallback (writes to ~/.gitconfig.local)
# Loaded for repos that don't match any includeIf path
setup-git:
    #!/usr/bin/env bash
    set -e
    local_file="$HOME/.gitconfig.local"

    if [[ -f "$local_file" ]]; then
      echo "~/.gitconfig.local already exists. Current contents:"
      echo "---"
      cat "$local_file"
      echo "---"
      read -rp "Overwrite it? [y/N] " confirm
      [[ "$confirm" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 1; }
    fi

    read -rp "Git name [default: Derek Eskens]: " git_name
    git_name="${git_name:-Derek Eskens}"

    read -rp "Git email [default: snekse@gmail.com]: " git_email
    git_email="${git_email:-snekse@gmail.com}"

    {
      echo "# Machine-local git identity fallback — not committed to repo"
      echo "# Generated by: just setup-git"
      echo "# Loaded for repos outside any includeIf path"
      echo ""
      echo "[user]"
      echo "  name = $git_name"
      echo "  email = $git_email"
    } > "$local_file"

    echo ""
    echo "Written to $local_file"

# Set up personal git identity (writes to ~/.gitconfig-personal)
# Loaded for repos under ~/dev/github/snekse/ via includeIf in .gitconfig
setup-git-personal:
    #!/usr/bin/env bash
    set -e
    local_file="$HOME/.gitconfig-personal"

    echo ""
    echo "Creates ~/.gitconfig-personal — loaded for repos under ~/dev/github/snekse/"
    read -rp "Set up personal git identity? [Y/n] " yn
    yn="${yn:-Y}"
    [[ "$yn" =~ ^[Yy]$ ]] || { echo "Skipping personal git setup."; exit 0; }

    if [[ -f "$local_file" ]]; then
      echo "$local_file already exists. Current contents:"
      echo "---"
      cat "$local_file"
      echo "---"
      read -rp "Overwrite it? [y/N] " confirm
      [[ "$confirm" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 1; }
    fi

    read -rp "Git name [default: Derek Eskens]: " git_name
    git_name="${git_name:-Derek Eskens}"

    read -rp "Git email [default: snekse@gmail.com]: " git_email
    git_email="${git_email:-snekse@gmail.com}"

    read -rp "GPG signing key ID (leave blank to skip): " signing_key

    {
      echo "# Personal git identity — not committed to repo"
      echo "# Generated by: just setup-git-personal"
      echo "# Loaded for repos under ~/dev/github/snekse/ via includeIf in .gitconfig"
      echo ""
      echo "[user]"
      echo "  name = $git_name"
      echo "  email = $git_email"
      if [[ -n "$signing_key" ]]; then
        echo "  signingkey = $signing_key"
      fi
    } > "$local_file"

    echo ""
    echo "Written to $local_file"

# Set up work git identity (writes to ~/.gitconfig-work)
# Loaded for repos under a configured work directory via includeIf in .gitconfig
setup-git-work:
    #!/usr/bin/env bash
    set -e
    local_file="$HOME/.gitconfig-work"

    echo ""
    echo "Creates ~/.gitconfig-work — loaded for repos under a configured work directory."
    read -rp "Set up work git identity? [y/N] " yn
    yn="${yn:-N}"
    [[ "$yn" =~ ^[Yy]$ ]] || { echo "Skipping work git setup."; exit 0; }

    if [[ -f "$local_file" ]]; then
      echo "$local_file already exists. Current contents:"
      echo "---"
      cat "$local_file"
      echo "---"
      read -rp "Overwrite it? [y/N] " confirm
      [[ "$confirm" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 1; }
    fi

    read -rp "Git name: " git_name
    [[ -z "$git_name" ]] && { echo "Name cannot be empty. Aborted."; exit 1; }

    read -rp "Git email: " git_email
    [[ -z "$git_email" ]] && { echo "Email cannot be empty. Aborted."; exit 1; }

    read -rp "GPG signing key ID (leave blank to skip): " signing_key

    {
      echo "# Work git identity — not committed to repo"
      echo "# Generated by: just setup-git-work"
      echo "# Loaded for repos under your work directory via includeIf in .gitconfig"
      echo ""
      echo "[user]"
      echo "  name = $git_name"
      echo "  email = $git_email"
      if [[ -n "$signing_key" ]]; then
        echo "  signingkey = $signing_key"
      fi
    } > "$local_file"

    echo ""
    echo "Written to $local_file"
